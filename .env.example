# Agent config
AGENT_NAME=google-ads
AGENT_DESCRIPTION=Google Ads campaign management and optimization
AGENT_CAPABILITIES=google-ads,campaigns,keywords,audiences,optimization,reporting
AGENT_SLACK_CHANNEL=#agent-google-ads
AGENT_PORT=3000
AGENT_ENDPOINT=http://localhost:3000

# Directus (ops.shoppingeventvip.be — single instance for all data)
DIRECTUS_URL=https://ops.shoppingeventvip.be
DIRECTUS_TOKEN=
DIRECTUS_INSTANCE=sev-ai

# Google Ads API
GOOGLE_ADS_DEVELOPER_TOKEN=
GOOGLE_ADS_CLIENT_ID=
GOOGLE_ADS_CLIENT_SECRET=
GOOGLE_ADS_REFRESH_TOKEN=
GOOGLE_ADS_CUSTOMER_ID=
GOOGLE_ADS_MANAGER_CUSTOMER_ID=

# Slack (direct posting for Block Kit — optional, falls back to OpenClaw text)
SLACK_BOT_TOKEN=
SLACK_SIGNING_SECRET=

# Event source (admin.shoppingeventvip.be — for event-linked campaigns)
WEBSITE_COLLAB_DIRECTUS_URL=https://admin.shoppingeventvip.be
WEBSITE_COLLAB_DIRECTUS_TOKEN=

# YouTube uploads (service account with domain-wide delegation)
GOOGLE_SA_KEY_PATH=/app/secrets/sev-ai-ops-sa.json
GOOGLE_IMPERSONATE_EMAIL=domien@shoppingeventvip.be

# LLM (strategy/copy generation)
ANTHROPIC_API_KEY=
